# Database (Supabase — direct connection for Prisma migrations)
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.umewpoesaoolfdcmpapc.supabase.co:5432/postgres"

# Database (Supabase — pooled connection for runtime queries via PgBouncer)
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.umewpoesaoolfdcmpapc.supabase.co:5432/postgres"

# JWT
JWT_SECRET="replace-with-a-strong-random-secret"
JWT_EXPIRES_IN="7d"

# App
PORT=3001
NODE_ENV=development
APP_URL="http://localhost:3000"

# Resend (email)
RESEND_API_KEY="re_replace_with_api_key"
RESEND_FROM_EMAIL="noreply@yourdomain.com"

# Cloudflare R2 (file storage)
R2_ACCOUNT_ID="replace"
R2_ACCESS_KEY_ID="replace"
R2_SECRET_ACCESS_KEY="replace"
R2_BUCKET_NAME="venue-photos"
R2_ENDPOINT="https://[ACCOUNT_ID].r2.cloudflarestorage.com/[BUCKET_NAME]"
R2_PUBLIC_URL="https://replace.r2.dev"
